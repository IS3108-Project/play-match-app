generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String           @id
  name                   String
  email                  String           @unique
  emailVerified          Boolean          @default(false)
  image                  String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  completedSteps         String?
  preferredAreas         String[]
  preferredTimes         String[]
  role                   UserRole         @default(USER)
  shouldOnboard          Boolean          @default(true)
  skillLevel             String?
  sportInterests         String[]
  bio                    String?
  locationSharingEnabled Boolean          @default(false)
  lastLatitude           Float?
  lastLocationAt         DateTime?
  lastLongitude          Float?
  matchRadius            Int              @default(25)
  banned                 Boolean          @default(false)
  bannedAt               DateTime?
  accounts               Account[]
  hostedActivities       Activity[]       @relation("hostedActivities")
  authoredComments       Comment[]        @relation("authoredComments")
  commentLikes           CommentLike[]
  authoredDiscussions    Discussion[]     @relation("authoredDiscussions")
  discussionLikes        DiscussionLike[]
  createdGroups          Group[]          @relation("createdGroups")
  groupMemberships       GroupMember[]
  invitedGuests          Guest[]          @relation("invitedGuests")
  participations         Participant[]
  reportsReceived        Report[]         @relation("reportsReceived")
  reportsFiled           Report[]         @relation("reportsFiled")
  sessions               Session[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Activity {
  id              String         @id @default(cuid())
  title           String
  description     String
  activityType    String
  date            DateTime
  startTime       String
  endTime         String
  location        String
  skillLevel      String
  maxParticipants Int
  requireApproval Boolean        @default(false)
  status          ActivityStatus @default(ACTIVE)
  imageSrc        String?
  hostId          String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  latitude        Float?
  longitude       Float?
  host            User           @relation("hostedActivities", fields: [hostId], references: [id], onDelete: Cascade)
  discussion      Discussion[]
  guests          Guest[]
  participants    Participant[]
  reports         Report[]

  @@index([hostId])
  @@index([date])
  @@index([status])
  @@map("activity")
}

model Participant {
  id               String            @id @default(cuid())
  userId           String
  activityId       String
  status           ParticipantStatus @default(CONFIRMED)
  joinedAt         DateTime          @default(now())
  rejectionNote    String?
  attendanceStatus AttendanceStatus  @default(PENDING)
  source           ParticipantSource @default(REQUESTED)
  activity         Activity          @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
  @@index([activityId, status])
  @@map("participant")
}

model Guest {
  id          String   @id @default(cuid())
  name        String
  contactType String
  contact     String
  activityId  String
  invitedById String
  createdAt   DateTime @default(now())
  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  invitedBy   User     @relation("invitedGuests", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@map("guest")
}

model Group {
  id              String        @id @default(cuid())
  name            String        @unique
  description     String
  icon            String
  iconBgColor     String
  profileImageUrl String?
  creatorId       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  discussions     Discussion[]
  creator         User          @relation("createdGroups", fields: [creatorId], references: [id], onDelete: Cascade)
  members         GroupMember[]

  @@index([creatorId])
  @@map("group")
}

model GroupMember {
  id       String   @id @default(cuid())
  userId   String
  groupId  String
  joinedAt DateTime @default(now())
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
  @@map("group_member")
}

model Discussion {
  id               String           @id @default(cuid())
  title            String
  content          String
  imageUrl         String?
  isPublic         Boolean          @default(true)
  authorId         String
  groupId          String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  linkedActivityId String?
  comments         Comment[]
  author           User             @relation("authoredDiscussions", fields: [authorId], references: [id], onDelete: Cascade)
  group            Group?           @relation(fields: [groupId], references: [id])
  activity         Activity?        @relation(fields: [linkedActivityId], references: [id])
  likes            DiscussionLike[]

  @@index([authorId])
  @@index([groupId])
  @@index([createdAt])
  @@map("discussion")
}

model DiscussionLike {
  id           String     @id @default(cuid())
  userId       String
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, discussionId])
  @@index([discussionId])
  @@map("discussion_like")
}

model Comment {
  id           String        @id @default(cuid())
  content      String
  authorId     String
  discussionId String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  author       User          @relation("authoredComments", fields: [authorId], references: [id], onDelete: Cascade)
  discussion   Discussion    @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  likes        CommentLike[]

  @@index([discussionId])
  @@map("comment")
}

model CommentLike {
  id        String  @id @default(cuid())
  userId    String
  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
  @@map("comment_like")
}

model Report {
  id             String       @id
  reporterId     String
  reportedUserId String
  activityId     String?
  type           ReportType
  details        String
  anonymous      Boolean      @default(false)
  status         ReportStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  resolvedAt     DateTime?
  adminNote      String?
  activity       Activity?    @relation(fields: [activityId], references: [id])
  reportedUser   User         @relation("reportsReceived", fields: [reportedUserId], references: [id], onDelete: Cascade)
  reporter       User         @relation("reportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([reportedUserId])
  @@map("report")
}

enum UserRole {
  USER
  ADMIN
}

enum ParticipantStatus {
  CONFIRMED
  PENDING
  WAITLISTED
  CANCELLED
  REJECTED
}

enum ActivityStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

enum AttendanceStatus {
  PENDING
  ATTENDED
  NO_SHOW
  LATE_CANCEL
  CANCELLED
  LATE
}

enum ReportType {
  NO_SHOW
  RUDE_UNSAFE
  MISREPRESENTED
  SPAM
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum ParticipantSource {
  REQUESTED
  INVITED
}
