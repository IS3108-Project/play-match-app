generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ───────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum ParticipantStatus {
  CONFIRMED
  PENDING
  WAITLISTED
  CANCELLED
  REJECTED
}

enum ActivityStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

enum AttendanceStatus {
  PENDING
  ATTENDED
  NO_SHOW
  LATE_CANCEL
  CANCELLED
}

enum ReportType {
  NO_SHOW
  RUDE_UNSAFE
  MISREPRESENTED
  SPAM
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

// ── Auth Domain ─────────────────────────────────────────────────────────

model User {
  id             String   @id
  name           String
  email          String   @unique
  emailVerified  Boolean  @default(false)
  image          String?
  role           UserRole @default(USER)
  bio            String?

  sportInterests String[]
  skillLevel     String?
  preferredTimes String[]
  preferredAreas String[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sessions       Session[]
  accounts       Account[]

  shouldOnboard  Boolean @default(true)
  completedSteps String?

  hostedActivities Activity[]    @relation("hostedActivities")
  participations   Participant[]
  invitedGuests    Guest[]       @relation("invitedGuests")
  reportsFiled     Report[]      @relation("reportsFiled")
  reportsReceived  Report[]      @relation("reportsReceived")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ── Activity Domain ─────────────────────────────────────────────────────

model Activity {
  id              String         @id @default(cuid())
  title           String
  description     String
  activityType    String
  date            DateTime
  startTime       String
  endTime         String
  location        String
  skillLevel      String
  maxParticipants Int
  requireApproval Boolean        @default(false)
  status          ActivityStatus @default(ACTIVE)
  imageSrc        String?

  hostId       String
  host         User          @relation("hostedActivities", fields: [hostId], references: [id], onDelete: Cascade)
  participants Participant[]
  guests       Guest[]
  reports      Report[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hostId])
  @@index([date])
  @@index([status])
  @@map("activity")
}

model Participant {
  id               String            @id @default(cuid())
  userId           String
  activityId       String
  status           ParticipantStatus @default(CONFIRMED)
  attendanceStatus AttendanceStatus  @default(PENDING)
  joinedAt         DateTime          @default(now())
  rejectionNote    String?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
  @@index([activityId, status])
  @@map("participant")
}

model Guest {
  id          String @id @default(cuid())
  name        String
  contactType String
  contact     String
  activityId  String
  invitedById String

  activity  Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  invitedBy User     @relation("invitedGuests", fields: [invitedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([activityId])
  @@map("guest")
}

// ── Report Domain ───────────────────────────────────────────────────────

model Report {
  id             String       @id
  reporterId     String
  reportedUserId String
  activityId     String?
  type           ReportType
  details        String
  anonymous      Boolean      @default(false)
  status         ReportStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  resolvedAt     DateTime?

  activity     Activity? @relation(fields: [activityId], references: [id])
  reporter     User      @relation("reportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser User      @relation("reportsReceived", fields: [reportedUserId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([reportedUserId])
  @@map("report")
}
