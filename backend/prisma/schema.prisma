generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Auth Domain ─────────────────────────────────────────────────────────

model User {
  id                     String           @id
  name                   String
  email                  String           @unique
  emailVerified          Boolean          @default(false)
  image                  String?
  role                   UserRole         @default(USER)
  bio                    String?
  banned                 Boolean          @default(false)
  bannedAt               DateTime?
  sportInterests         String[]
  skillLevel             String?
  preferredTimes         String[]
  preferredAreas         String[]
  locationSharingEnabled Boolean          @default(false)
  emailNotificationsEnabled Boolean        @default(true)
  activityRemindersEnabled  Boolean        @default(true)
  lastLatitude           Float?
  lastLongitude          Float?
  lastLocationAt         DateTime?
  matchRadius            Int              @default(25)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  shouldOnboard          Boolean          @default(true)
  completedSteps         String?
  sessions               Session[]
  accounts               Account[]
  hostedActivities       Activity[]       @relation("hostedActivities")
  participations         Participant[]
  invitedGuests          Guest[]          @relation("invitedGuests")
  reportsFiled           Report[]         @relation("reportsFiled")
  reportsReceived        Report[]         @relation("reportsReceived")
  createdGroups          Group[]          @relation("createdGroups")
  groupMemberships       GroupMember[]
  authoredDiscussions    Discussion[]     @relation("authoredDiscussions")
  discussionLikes        DiscussionLike[]
  authoredComments       Comment[]        @relation("authoredComments")
  commentLikes           CommentLike[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ── Activity Domain ─────────────────────────────────────────────────────

model Activity {
  id              String         @id @default(cuid())
  title           String
  description     String
  activityType    String
  date            DateTime
  startTime       String
  endTime         String
  location        String
  latitude        Float?
  longitude       Float?
  skillLevel      String
  maxParticipants Int
  requireApproval Boolean        @default(false)
  status          ActivityStatus @default(ACTIVE)
  imageSrc        String?
  hostId          String
  host            User           @relation("hostedActivities", fields: [hostId], references: [id], onDelete: Cascade)
  participants    Participant[]
  guests          Guest[]
  reports         Report[]
  linkedDiscussions Discussion[] @relation("linkedDiscussions")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([hostId])
  @@index([date])
  @@index([status])
  @@map("activity")
}

model Participant {
  id               String            @id @default(cuid())
  userId           String
  activityId       String
  status           ParticipantStatus @default(CONFIRMED)
  source           ParticipantSource @default(REQUESTED)
  attendanceStatus AttendanceStatus  @default(PENDING)
  joinedAt         DateTime          @default(now())
  rejectionNote    String?
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity         Activity          @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
  @@index([activityId, status])
  @@map("participant")
}

model Guest {
  id          String   @id @default(cuid())
  name        String
  contactType String
  contact     String
  activityId  String
  invitedById String
  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  invitedBy   User     @relation("invitedGuests", fields: [invitedById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([activityId])
  @@map("guest")
}

// ── Community Domain ─────────────────────────────────────────────────────

model Group {
  id              String        @id @default(cuid())
  name            String        @unique
  description     String
  icon            String
  iconBgColor     String
  profileImageUrl String?
  creatorId       String
  creator         User          @relation("createdGroups", fields: [creatorId], references: [id], onDelete: Cascade)
  members         GroupMember[]
  discussions     Discussion[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([creatorId])
  @@map("group")
}

model GroupMember {
  id       String   @id @default(cuid())
  userId   String
  groupId  String
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
  @@map("group_member")
}

model Discussion {
  id               String           @id @default(cuid())
  title            String
  content          String
  imageUrl         String?
  isPublic         Boolean          @default(true)
  authorId         String
  author           User             @relation("authoredDiscussions", fields: [authorId], references: [id], onDelete: Cascade)
  groupId          String?
  group            Group?           @relation(fields: [groupId], references: [id], onDelete: SetNull)
  linkedActivityId String?
  linkedActivity   Activity?        @relation("linkedDiscussions", fields: [linkedActivityId], references: [id], onDelete: SetNull)
  likes            DiscussionLike[]
  comments         Comment[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([authorId])
  @@index([groupId])
  @@index([createdAt])
  @@map("discussion")
}

model DiscussionLike {
  id           String     @id @default(cuid())
  userId       String
  discussionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@unique([userId, discussionId])
  @@index([discussionId])
  @@map("discussion_like")
}

model Comment {
  id           String        @id @default(cuid())
  content      String
  authorId     String
  discussionId String
  author       User          @relation("authoredComments", fields: [authorId], references: [id], onDelete: Cascade)
  discussion   Discussion    @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  likes        CommentLike[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([discussionId])
  @@map("comment")
}

model CommentLike {
  id        String  @id @default(cuid())
  userId    String
  commentId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
  @@map("comment_like")
}

// ── Report Domain ───────────────────────────────────────────────────────

model Report {
  id             String       @id
  reporterId     String
  reportedUserId String
  activityId     String?
  type           ReportType
  details        String
  anonymous      Boolean      @default(false)
  status         ReportStatus @default(PENDING)
  adminNote      String?
  createdAt      DateTime     @default(now())
  resolvedAt     DateTime?
  activity       Activity?    @relation(fields: [activityId], references: [id])
  reporter       User         @relation("reportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser   User         @relation("reportsReceived", fields: [reportedUserId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([reportedUserId])
  @@map("report")
}

// ── Enums ────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum ParticipantStatus {
  CONFIRMED
  PENDING
  WAITLISTED
  CANCELLED
  REJECTED
}

enum ActivityStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

enum AttendanceStatus {
  PENDING
  ATTENDED
  NO_SHOW
  LATE_CANCEL
  CANCELLED
  LATE
}

enum ReportType {
  NO_SHOW
  RUDE_UNSAFE
  MISREPRESENTED
  SPAM
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum ParticipantSource {
  REQUESTED
  INVITED
}

// ── Admin Audit Log ────────────────────────────────────────────────────

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminId     String
  action      String   // BAN_USER, UNBAN_USER, DELETE_ACTIVITY, DELETE_DISCUSSION, RESOLVE_REPORT, etc.
  targetType  String   // USER, ACTIVITY, DISCUSSION, REPORT
  targetId    String
  details     Json?    // Additional context (e.g., ban reason, admin note)
  createdAt   DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
  @@index([targetType, targetId])
  @@map("admin_audit_log")
}
